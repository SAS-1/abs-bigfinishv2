{
  "id": "librofm",
  "name": "Libro.fm",
  "available": true,
  "description": "Fetches metadata from Libro.fm, a DRM-free audiobook retailer.",
  "url": "https://libro.fm",
  "parameters": [
    {
      "name": "limit",
      "required": false,
      "validation": {
        "type": "int",
        "min": 1,
        "max": 20
      },
      "description": "Maximum results to return"
    },
    {
      "name": "searchby",
      "required": false,
      "validation": {
        "type": "enum",
        "values": ["all", "titles", "authors"]
      },
      "description": "Field to search by (titles or authors). If not specified, defaults to searching by all."
    },
